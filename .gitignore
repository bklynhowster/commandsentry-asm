# COMMANDsentry .gitignore
# Keep target list, raw scan artifacts, and secrets out of git.
# We DO commit normalized findings JSON (per D-004).

# NOTE: targets.yml IS committed to this private repo so the GitHub Actions
# workflow knows what to scan. Scope-verification gating (`scope_verified: true`)
# is the abuse rail; gitignore is not.

# Raw scan artifacts (text dumps, screenshots, large files)
data/raw/
scans/
*.tar.gz
*.zip

# Scope authorization PDFs (signed letters for third-party targets)
docs/scope-auth/

# Secrets (defense in depth — Actions secrets handle this for real)
.env
.env.local
*.pem
*.key
*credentials*
*token*
!*.example*

# Local scratch
.DS_Store
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Editor
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
web/dist/
web/build/

# Local scanner debug output
scanner/_debug/
scanner/output/
