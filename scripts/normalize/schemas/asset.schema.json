{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commandsentry/schemas/asset.schema.json",
  "title": "Asset",
  "description": "A target being assessed — apex domain, single host, IP, mail server, API host, etc. Mirrors COMMANDsentry's apex-as-asset shape but adds organization linkage.",
  "type": "object",
  "required": ["asset_id", "name", "type", "organization"],
  "properties": {
    "asset_id":     { "type": "string", "description": "Stable identifier. For domains: the apex (commandcommcentral.com). For IP-only targets: ip:<address>. For single hosts: the FQDN." },
    "name":         { "type": "string", "description": "Human-readable name shown in dashboards." },
    "type":         { "type": "string", "enum": ["apex_domain", "single_host", "ip", "ip_range", "mail_server", "vpn_endpoint", "api_host"] },
    "organization": { "type": "string", "enum": ["command_companies", "command_digital", "command_financial", "command_missouri", "command_marketing", "unimat", "sci"] },
    "tags":         { "type": "array", "items": { "type": "string" } },
    "first_observed":  { "type": "string", "format": "date-time", "description": "Earliest scan date that observed this asset." },
    "last_observed":   { "type": "string", "format": "date-time", "description": "Most recent scan date that observed this asset." },
    "current_risk":    { "type": "string", "enum": ["CRITICAL", "HIGH", "MODERATE-HIGH", "MODERATE", "LOW", "INFO", "UNKNOWN"] },
    "subdomains":      { "type": "array", "items": { "$ref": "subdomain.schema.json" } },
    "metadata":        { "type": "object", "description": "Free-form: hosting, registrar, WAF, etc.", "additionalProperties": true }
  },
  "additionalProperties": false
}
